// Dev Container configuration for Spring Boot + optional front-end + PostgreSQL.
// See https://containers.dev/implementors/json_reference/
{
    "name": "Spring Boot Dev Environment",
    "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

    // JDK 25 + Node 24 features
    "features": {
        "ghcr.io/devcontainers/features/java:1": {
            "version": "25"
        },
        "ghcr.io/devcontainers/features/node:1": {
            "version": "24"
        },
        "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
    },

    // VS Code extensions to install inside the container
    "customizations": {
        "vscode": {
            "extensions": [
                "redhat.java",
                "vscjava.vscode-java-pack",
                "pivotal.vscode-spring-boot",
                "vmware.vscode-boot-dev-pack",
                "redhat.vscode-yaml",
                "ms-azuretools.vscode-docker",
                "dbaeumer.vscode-eslint",
                "esbenp.prettier-vscode"
            ],
            "settings": {
                "java.compile.nullAnalysis.mode": "automatic",
                "editor.formatOnSave": true,
                "files.eol": "\n"
            }
        }
    },

    // Lifecycle hooks
    "postCreateCommand": "./gradlew dependencies --no-daemon -q || true",
    "postStartCommand": "echo '✅ Dev container ready — run ./gradlew bootRun'",

    // Forward app + front-end dev ports
    "forwardPorts": [8080, 5173, 5432],
    "portsAttributes": {
        "8080": { "label": "Spring Boot", "onAutoForward": "notify" },
        "5173": { "label": "Vite Dev Server", "onAutoForward": "silent" },
        "5432": { "label": "PostgreSQL", "onAutoForward": "silent" }
    },

    // Run as non-root
    "remoteUser": "vscode"
}
