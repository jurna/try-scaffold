# Spring profiles
SPRING_PROFILES_ACTIVE=dev

# MongoDB
SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/mydb

# Application secrets (NEVER commit real values)
APP_API_KEY=replace-me
APP_API_SECRET=replace-me

# Microsoft Entra ID (single-tenant social login)
# See references/SOCIAL-LOGIN.md for app registration steps.
MS_CLIENT_ID=replace-me
MS_CLIENT_SECRET=replace-me
MS_TENANT_ID=replace-me
